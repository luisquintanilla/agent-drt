@code {
    // Decision constants for Razor event handlers
    private const string DecisionApprove = "approve";
    private const string DecisionRevise = "revise";
    private const string DecisionReject = "reject";

    // State
    private List<WorkflowRunSummary> workflows = [];
    private WorkflowRun? selectedWorkflow;
    private bool isLoadingWorkflows = true;
    private bool isStartingWorkflow = false;
    private bool isSubmittingApproval = false;
    private bool isCancelling = false;
    private string? submittingRequestId;
    private string? submittingDecision;

    // Form inputs
    private string newWorkflowTopic = "";
    private string newWorkflowAudience = "";
    private string approvalFeedback = "";

    // Notifications
    private string? notificationMessage;
    private string notificationType = "info";

    // DTO for parsing approval request data
    private sealed class ApprovalRequestDto
    {
        public string? Content { get; init; }
        public IReadOnlyList<string>? Options { get; init; }
    }

    protected override async Task OnInitializedAsync()
    {
        await RefreshWorkflows();
    }

    private async Task RefreshWorkflows()
    {
        isLoadingWorkflows = true;
        StateHasChanged();

        try
        {
            var response = await WorkflowClient.ListWorkflowsAsync(new ListWorkflowsRequest { Limit = 50 });
            workflows = response.Data;
            Logger.LogInformation("Loaded {Count} workflows", workflows.Count);

            // Refresh selected workflow if it exists
            if (selectedWorkflow != null)
            {
                await SelectWorkflow(selectedWorkflow.Id);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load workflows");
            ShowNotification("Failed to load workflows: " + ex.Message, "error");
        }
        finally
        {
            isLoadingWorkflows = false;
            StateHasChanged();
        }
    }

    private async Task StartNewWorkflow()
    {
        if (string.IsNullOrWhiteSpace(newWorkflowTopic))
            return;

        isStartingWorkflow = true;
        StateHasChanged();

        try
        {
            var request = new StartWorkflowRequest
            {
                WorkflowName = "MarketingContentWorkflow",
                Input = WorkflowMessage.Create(new
                {
                    Topic = newWorkflowTopic,
                    TargetAudience = newWorkflowAudience
                })
            };

            var workflow = await WorkflowClient.StartWorkflowAsync(request);
            Logger.LogInformation("Started workflow: {WorkflowId}", workflow.Id);

            newWorkflowTopic = "";
            newWorkflowAudience = "";
            ShowNotification("Workflow started successfully!", "success");

            await RefreshWorkflows();
            await SelectWorkflow(workflow.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to start workflow");
            ShowNotification("Failed to start workflow: " + ex.Message, "error");
        }
        finally
        {
            isStartingWorkflow = false;
            StateHasChanged();
        }
    }

    private async Task SelectWorkflow(string workflowId)
    {
        try
        {
            selectedWorkflow = await WorkflowClient.GetWorkflowAsync(workflowId);
            if (selectedWorkflow == null)
            {
                ShowNotification("Workflow not found", "error");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to get workflow details: {WorkflowId}", workflowId);
            ShowNotification("Failed to load workflow details: " + ex.Message, "error");
        }

        StateHasChanged();
    }

    private async Task SubmitApproval(string requestId, string decision)
    {
        if (selectedWorkflow == null)
            return;

        isSubmittingApproval = true;
        submittingRequestId = requestId;
        submittingDecision = decision;
        StateHasChanged();

        try
        {
            var signal = new WorkflowSignal
            {
                RequestId = requestId,
                Response = WorkflowMessage.Create(new
                {
                    Decision = decision,
                    Feedback = approvalFeedback
                })
            };

            var updatedWorkflow = await WorkflowClient.SendSignalAsync(selectedWorkflow.Id, signal);
            Logger.LogInformation("Submitted approval for workflow {WorkflowId}: {Decision}", selectedWorkflow.Id, decision);

            approvalFeedback = "";
            selectedWorkflow = updatedWorkflow;
            ShowNotification($"Decision '{decision}' submitted successfully!", "success");

            await RefreshWorkflows();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to submit approval for workflow {WorkflowId}", selectedWorkflow.Id);
            ShowNotification("Failed to submit approval: " + ex.Message, "error");
        }
        finally
        {
            isSubmittingApproval = false;
            submittingRequestId = null;
            submittingDecision = null;
            StateHasChanged();
        }
    }

    private async Task CancelSelectedWorkflow()
    {
        if (selectedWorkflow == null)
            return;

        isCancelling = true;
        StateHasChanged();

        try
        {
            var updatedWorkflow = await WorkflowClient.CancelWorkflowAsync(selectedWorkflow.Id);
            Logger.LogInformation("Cancelled workflow: {WorkflowId}", selectedWorkflow.Id);

            selectedWorkflow = updatedWorkflow;
            ShowNotification("Workflow cancelled", "info");

            await RefreshWorkflows();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to cancel workflow {WorkflowId}", selectedWorkflow.Id);
            ShowNotification("Failed to cancel workflow: " + ex.Message, "error");
        }
        finally
        {
            isCancelling = false;
            StateHasChanged();
        }
    }

    private void ShowNotification(string message, string type)
    {
        notificationMessage = message;
        notificationType = type;
        StateHasChanged();

        // Auto-dismiss after 5 seconds
        _ = Task.Run(async () =>
        {
            await Task.Delay(5000);
            await InvokeAsync(() =>
            {
                if (notificationMessage == message)
                {
                    notificationMessage = null;
                    StateHasChanged();
                }
            });
        });
    }

    private static string GetStatusClass(WorkflowRunStatus status) => status switch
    {
        WorkflowRunStatus.Queued => "status-queued",
        WorkflowRunStatus.Running => "status-running",
        WorkflowRunStatus.WaitingForSignal => "status-waiting",
        WorkflowRunStatus.Cancelling => "status-waiting",
        WorkflowRunStatus.Completed => "status-completed",
        WorkflowRunStatus.Cancelled => "status-cancelled",
        WorkflowRunStatus.Aborted => "status-aborted",
        WorkflowRunStatus.Failed => "status-failed",
        _ => ""
    };
}
